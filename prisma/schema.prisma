generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Auth.js v5 tables ──────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // JOL-specific
  purpose       String?   // vendas, contabil, rh, cobranca, etc
  newsletterOptIn Boolean @default(true)
  plan          String    @default("free") // free, pro, business, api

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastSeenAt    DateTime?

  accounts      Account[]
  sessions      Session[]
  consultations Consultation[]
  apiKeys       ApiKey[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── JOL business tables ────────────────────────────────────────

// Logs every CNPJ consultation by registered users (rate limiting + analytics)
model Consultation {
  id        String   @id @default(cuid())
  userId    String?
  cnpj      String
  type      String   @default("view") // view, export, api
  ip        String?
  ua        String?  @db.Text
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([cnpj, createdAt])
}

// Lead capture (when user signs up — denormalized so we never lose this even if user is deleted)
model Lead {
  id           String   @id @default(cuid())
  email        String
  name         String?
  purpose      String?
  newsletter   Boolean  @default(true)
  source       String?  // organic, ads, referral
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  ip           String?
  ua           String?  @db.Text
  createdAt    DateTime @default(now())
  syncedToCrm  Boolean  @default(false)
  syncedAt     DateTime?

  @@index([email])
  @@index([createdAt])
}

// API Keys (future paid feature)
model ApiKey {
  id          String   @id @default(cuid())
  userId      String
  name        String
  keyPrefix   String   @unique // e.g. "jol_live_"
  keyHash     String   // sha256 of full key
  rateLimit   Int      @default(60) // req/min
  monthlyQuota Int     @default(1000)
  monthlyUsed  Int     @default(0)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  expiresAt   DateTime?
  lastUsedAt  DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// Sócios (QSA) extraídos da Receita Federal (zips Socios0-6.zip)
// Cada CNPJ pode ter múltiplos sócios. Indexado por cnpjBasico (8 dígitos).
// 1 = Pessoa Jurídica, 2 = Pessoa Física, 3 = Estrangeiro
model Socio {
  id                String   @id @default(cuid())
  cnpjBasico        String   // primeiros 8 dígitos do CNPJ
  identificadorTipo Int      // 1=PJ, 2=PF, 3=Estrangeiro
  nome              String   // nome do sócio ou razão social
  nomeSlug          String   // slug normalizado para URL/busca
  cnpjCpfSocio      String?  // mascarado (XXX...XX)
  qualificacao      Int?     // código RFB de qualificação
  qualificacaoDesc  String?  // descrição da qualificação
  dataEntrada       String?  // YYYYMMDD
  pais              String?
  representanteCpf  String?
  representanteNome String?
  qualifRepresent   Int?
  faixaEtaria       Int?     // 1=0-12 ... 9=80+

  createdAt         DateTime @default(now())

  @@index([cnpjBasico])
  @@index([nomeSlug])
  @@index([nome])
}

// LGPD: requests for company data removal
model RemovalRequest {
  id          String   @id @default(cuid())
  cnpj        String
  requesterName  String
  requesterCpf   String?
  requesterEmail String
  reason      String   @db.Text
  status      String   @default("pending") // pending, approved, rejected, processed
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  processedAt DateTime?
}
